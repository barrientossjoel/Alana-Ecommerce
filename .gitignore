# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Bun ──────────────────────────────────────────────────────────────────────
bun.lockb
# Si usás bun.lock (text lockfile), descomentá:
# bun.lock

# ─── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Drizzle / SQLite / Turso ─────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
drizzle/meta/
.turso/

# ─── Environment variables ────────────────────────────────────────────────────
.env*
!.env.example

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ─── Debug / Logs ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*
*.log

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/
*.swp
*.swo
